# ─────────────────────────────────────────
# LuxeCart Web Environment Variables
# ─────────────────────────────────────────
# Copy this file to .env.local and fill in the values.
# This .env.example file IS committed to Git.
# The actual .env.local file is gitignored.
#
# NEXT_PUBLIC_ prefix means the variable is exposed to the browser.
# Variables WITHOUT this prefix are only available on the server.
# Never put secrets in NEXT_PUBLIC_ variables.

# API Configuration
NEXT_PUBLIC_API_URL=http://localhost:5000/api/v1

# App Configuration
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=LuxeCart