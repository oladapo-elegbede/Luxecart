# ─────────────────────────────────────────
# LuxeCart API Environment Variables
# ─────────────────────────────────────────
# Copy this file to .env and fill in the values.
# This .env.example file IS committed to Git.
# The actual .env file is gitignored.

# Server Configuration
NODE_ENV=development
PORT=5000
API_URL=http://localhost:5000
CLIENT_URL=http://localhost:3000

# Database (PostgreSQL — Supabase or local)
# Format: postgresql://username:password@host:port/database
DATABASE_URL=postgresql://postgres:your_password_here@your-project.supabase.co:5432/postgres


# JWT Authentication (generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))")
JWT_ACCESS_SECRET=your_access_secret_64_chars_minimum_replace_this_value
JWT_REFRESH_SECRET=your_refresh_secret_64_chars_minimum_replace_this_value
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

STRIPE_SECRET_KEY=sk_test_your_secret_key_here
STRIPE_PUBLISHABLE_KEY=pk_test_your_publishable_key_here
STRIPE_WEBHOOK_SECRET=whsec_generated_by_stripe_cli